# ─────────────────────────────────────────────
# ARDOR Backend — Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# Supabase — get these from your project's API settings
# https://app.supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Anthropic — get from https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud TTS — path to your service account JSON file
# Create at https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_APPLICATION_CREDENTIALS=./google_credentials.json

# Gmail OAuth — created via Google Cloud Console → APIs → Gmail API
# Download the OAuth client credentials JSON and put the path here
GMAIL_CREDENTIALS_FILE=./gmail_credentials.json
# After first run, the OAuth token is cached here automatically
GMAIL_TOKEN_FILE=./gmail_token.json

# The Gmail address that receives the newsletters
GMAIL_USER=ardor.news@gmail.com

# Scheduler — time to run the daily pipeline (24h format, server local time)
PIPELINE_HOUR=7
PIPELINE_MINUTE=0

# App environment (development | production)
APP_ENV=development
